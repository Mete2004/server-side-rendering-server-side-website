    {% assign mobile_logo = "/assets/logo-compact-nieuw-west.svg" %}
    {% assign desktop_logo = "/assets/logo-lang-nieuw-west.svg" %}

    {% render 'partials/head.liquid',
        mobile_logo: mobile_logo,
        desktop_logo: desktop_logo
    %}

    <main class="main-nieuw-west">

        <section class="section-cards">
            <div class="cards">
                {% for story in stories %}
                    {% render 'partials/card.liquid', story: story, categories: categories %}
                {% endfor %}
            </div>
        </section>

    </main>
    
    {% render 'partials/foot.liquid'%}