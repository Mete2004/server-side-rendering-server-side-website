    {% assign mobile_logo = "/assets/logo-compact-home.svg" %}
    {% assign desktop_logo = "/assets/logo-lang-home.svg" %}
    
    {% render 'partials/head.liquid',
        mobile_logo: mobile_logo,
        desktop_logo: desktop_logo
    %}

    <article class="article">

        <a href="javascript:history.back()" class="back-link">
            ← Terug
        </a>

        <p>{{ story.district }}</p>

        {% for category in categories %}
            {% if category.id == story.categories[0] %}
                <p>{{ category.title }}</p>
            {% endif %}
        {% endfor %}

        <h1>{{ story.title }}</h1>

        <p>{{ story.intro }}</p>

        {{ story.body }}


    </article>

  {% render 'partials/foot.liquid'%}